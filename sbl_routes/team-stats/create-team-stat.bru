meta {
  name: Create Team Stat
  type: http
  seq: 3
}

post {
  url: {{base_url}}/api/team-stats
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "team": 1,
    "division": 1,
    "wins": 0,
    "losses": 0,
    "ties": 0,
    "winRounds": 0,
    "looseRounds": 0,
    "points": 0
  }
}
