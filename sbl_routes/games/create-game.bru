meta {
  name: Create Game
  type: http
  seq: 3
}

post {
  url: {{base_url}}/api/games
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "team1": 1,
    "team2": 2,
    "division": 1,
    "status": 1,
    "week": 1,
    "date": "2026-01-06",
    "score1": 0,
    "score2": 0,
    "winner": null
  }
}
