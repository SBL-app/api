meta {
  name: Generate Division Schedule
  type: http
  seq: 11
}

post {
  url: {{base_url}}/api/divisions/1/schedule
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "type": "round_robin",
    "status_id": 1,
    "start_date": "2026-01-06",
    "days_between_weeks": 7
  }
}
